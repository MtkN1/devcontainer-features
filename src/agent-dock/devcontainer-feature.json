{
	"containerEnv": {
		"AGENT_DOCK_BASE_DIR": "/mnt/agent-dock"
	},
	"id": "agent-dock",
	"mounts": [
		{
			"source": "agent-dock",
			"target": "/mnt/agent-dock/secrets",
			"type": "volume"
		}
	],
	"name": "Agent Dock",
	"options": {
		"installClaudeCode": {
			"default": true,
			"description": "Install Claude Code",
			"type": "boolean"
		},
		"installCodexCli": {
			"default": true,
			"description": "Install Codex CLI",
			"type": "boolean"
		},
		"installGeminiCli": {
			"default": true,
			"description": "Install Gemini CLI",
			"type": "boolean"
		},
		"installGitHubCopilotCli": {
			"default": true,
			"description": "Install GitHub Copilot CLI",
			"type": "boolean"
		}
	},
	"version": "0.0.1",
	"postCreateCommand": [
		"/usr/bin/env",
		"bash",
		"/mnt/agent-dock/lib/setup.sh"
	]
}