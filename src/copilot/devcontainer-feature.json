{
	"id": "copilot",
	"version": "0.0.4",
	"name": "GitHub Copilot CLI",
	"containerEnv": {
		"COPILOT_EDITOR": "code --wait",
		"COPILOT_HOME": "/mnt/agent-dock/.copilot"
	},
	"mounts": [
		{
			"source": "agent-dock-copilot-${devcontainerId}",
			"target": "/mnt/agent-dock/.copilot",
			"type": "volume"
		},
		{
			"source": "agent-dock-copilot-bin",
			"target": "/mnt/agent-dock/libexec/copilot",
			"type": "volume"
		}
	],
	"updateContentCommand": [
		"/usr/bin/env",
		"bash",
		"/mnt/agent-dock/lib/copilot/setup.sh"
	]
}